                "verify-register-otp"
              ]
            },
            "description": "Verifikasi OTP setelah register. Mengembalikan token JWT."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "  console.log('Token tersimpan:', json.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
