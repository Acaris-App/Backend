    {
      "name": "Document",
      "item": [
        {
          "name": "Get Dokumen (List)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/document/list",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "document",
                "list"
              ],
              "query": [
                {
                  "key": "document_type",
                  "value": "krs",
                  "description": "Filter: krs | khs | transkrip (opsional)",
                  "disabled": true
                },
                {
                  "key": "semester",
                  "value": "1",
                  "description": "Filter by semester (opsional)",
                  "disabled": true
                }
              ]
            },
            "description": "Ambil semua dokumen milik mahasiswa, dikelompokkan per type (krs, khs, transkrip). Bisa difilter dengan query param ?document_type=krs atau ?semester=1."
          }
        },
        {
          "name": "Upload Dokumen",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "",
                  "description": "File PDF wajib diisi"
                },
                {
                  "key": "document_type",
                  "value": "krs",
                  "type": "text",
                  "description": "krs | khs | transkrip"
                },
                {
                  "key": "semester",
                  "value": "1",
                  "type": "text",
                  "description": "Wajib untuk krs/khs. Tidak perlu untuk transkrip."
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/document/upload",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "document",
                "upload"
              ]
            },
            "description": "Upload dokumen KRS/KHS/Transkrip. Hanya mahasiswa. Field 'file' (PDF) wajib ada."
          }
        },
        {
          "name": "Update Dokumen",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "",
                  "description": "File PDF pengganti"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/document/update/:document_id",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "document",
                "update",
                ":document_id"
              ],
              "variable": [
                {
                  "key": "document_id",
                  "value": "1",
                  "description": "ID dokumen yang ingin diupdate"
                }
              ]
            },
            "description": "Replace/update file dokumen yang sudah ada. Hanya milik user sendiri."
          }
        },
        {
          "name": "Check Kelengkapan Dokumen",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/document/check",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "document",
                "check"
              ]
            },
            "description": "Cek kelengkapan dokumen KRS dan KHS per semester. Hanya mahasiswa."
          }
        },
        {
          "name": "Delete Dokumen",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/document/delete/:document_id",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "document",
                "delete",
                ":document_id"
              ],
              "variable": [
                {
                  "key": "document_id",
                  "value": "1",
                  "description": "ID dokumen yang ingin dihapus"
                }
              ]
            },
            "description": "Hapus dokumen milik mahasiswa. File juga dihapus dari GCS. Hanya bisa hapus dokumen milik sendiri."
          }
        }
      ]
