      "item": [
        {
          "name": "Validate Kode Kelas",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"kode_kelas\": \"DSN-ABCD\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/validate-kode-kelas",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "validate-kode-kelas"
              ]
            },
            "description": "Step 1 multi-step register Android \u2014 validasi kode kelas sebelum user isi data diri. Mengembalikan nama dosen PA jika kode valid."
          }
        },
        {
